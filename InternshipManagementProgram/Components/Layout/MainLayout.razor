@inherits LayoutComponentBase
@implements IDisposable
@inject AppState AppState
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!AppState.IsLoggedIn)
{
    @* Login i strony publiczne renderujemy bez sidebar/topbar *@
    @Body
}
else
{
    <div class="app">
        <Sidebar />
        <main class="main">
            <Topbar />
            <div class="content">
                @Body
            </div>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    Wystąpił nieoczekiwany błąd.
    <a href="." class="reload">Przeładuj</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private static readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#36b24c",
            Secondary = "#f0c419",
            Tertiary = "#1f2f5e",
            Success = "#4ac255",
            Error = "#f15463",
            Info = "#4d8df6",
            Warning = "#f0c419",
            Background = "#131c34",
            Surface = "#1a2547",
            DrawerBackground = "#0e1530",
            AppbarBackground = "#131c34",
            TextPrimary = "rgba(255,255,255,0.94)",
            TextSecondary = "rgba(220,228,248,0.62)",
            ActionDefault = "rgba(255,255,255,0.62)",
            LinesDefault = "rgba(255,255,255,0.07)",
            TableLines = "rgba(255,255,255,0.07)",
            DividerLight = "rgba(255,255,255,0.07)",
            ActionDisabled = "rgba(220,228,248,0.38)",
            ActionDisabledBackground = "rgba(255,255,255,0.04)",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Inter", "system-ui", "-apple-system", "Segoe UI", "Roboto", "sans-serif" }
            }
        }
    };

    protected override void OnInitialized()
    {
        AppState.Changed += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => AppState.Changed -= OnChanged;
}
