@page "/student/zglos"
@rendermode InteractiveServer
@inject IDbContextFactory<PraktykiStudenckieContext> DbFactory
@inject AppState AppState
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nowe zgloszenie - PraktykiStud</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Zgloszenie nowej praktyki</h1>
        <p class="page-sub">Wypelnij dane praktyki - po wyslaniu zgloszenie trafia do pelnomocnika ds. praktyk.</p>
    </div>
    <div class="row">
        <a class="btn btn-text" href="/student">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" /> Wroc do listy
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else
        {
            <div class="form-grid">
                <div class="form-field required full">
                    <label>Firma / Instytucja</label>
                    <select class="field" @bind="_idFirmy">
                        <option value="">— wybierz firme —</option>
                        @foreach (var f in _firmy)
                        {
                            <option value="@f.Idfirmy">@f.NazwaFirmy - @f.Miasto</option>
                        }
                    </select>
                    <span class="hint">Lista zatwierdzonych firm partnerskich uczelni.</span>
                </div>

                <div class="form-field required">
                    <label>Opiekun praktyki (uczelniany)</label>
                    <select class="field" @bind="_idOpiekuna">
                        <option value="">— wybierz opiekuna —</option>
                        @foreach (var o in _opiekunowie)
                        {
                            <option value="@o.Idopiekuna">@(o.Tytul ?? "") @o.Imie @o.Nazwisko</option>
                        }
                    </select>
                </div>

                <div class="form-field">
                    <label>Osoba kontaktowa w firmie (opcjonalnie)</label>
                    <select class="field" @bind="_idOsoby" disabled="@(_idFirmy is null)">
                        <option value="">— brak / wybierz po wyborze firmy —</option>
                        @foreach (var o in OsobyDlaFirmy())
                        {
                            <option value="@o.Idosoby">@o.Imie @o.Nazwisko (@(o.Stanowisko ?? "—"))</option>
                        }
                    </select>
                </div>

                <div class="form-field required">
                    <label>Rodzaj praktyki</label>
                    <input class="field" maxlength="50" @bind="_rodzaj" placeholder="np. Obowiazkowa, Wakacyjna..." />
                </div>

                <div class="form-field"></div>

                <div class="form-field required">
                    <label>Data rozpoczecia</label>
                    <input class="field" type="date" @bind="_dataRozp" />
                </div>

                <div class="form-field required">
                    <label>Data zakonczenia</label>
                    <input class="field" type="date" @bind="_dataZak" />
                </div>
            </div>

            <div class="form-actions">
                <a class="btn btn-text" href="/student">Anuluj</a>
                <button class="btn btn-primary" @onclick="HandleSubmit" disabled="@(_submitting || !IsValid)">
                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" />
                    @(_submitting ? "Wysylanie..." : "Wyslij do akceptacji")
                </button>
            </div>
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private bool _submitting;

    private List<Firma> _firmy = new();
    private List<Opiekun> _opiekunowie = new();
    private List<OsobaKontaktowa> _osoby = new();

    private int? _idFirmy;
    private int? _idOpiekuna;
    private int? _idOsoby;
    private string _rodzaj = "";
    private DateTime? _dataRozp;
    private DateTime? _dataZak;

    private bool IsValid => _idFirmy is not null && _idOpiekuna is not null
        && !string.IsNullOrWhiteSpace(_rodzaj)
        && _dataRozp is not null && _dataZak is not null;

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.IsStudent)
        {
            Nav.NavigateTo("/login");
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        _firmy = await db.Firmas.OrderBy(f => f.NazwaFirmy).ToListAsync();
        _opiekunowie = await db.Opiekuns.OrderBy(o => o.Nazwisko).ThenBy(o => o.Imie).ToListAsync();
        _osoby = await db.OsobaKontaktowas.ToListAsync();
        _loading = false;
    }

    private IEnumerable<OsobaKontaktowa> OsobyDlaFirmy()
        => _idFirmy is null ? Enumerable.Empty<OsobaKontaktowa>() : _osoby.Where(o => o.Idfirmy == _idFirmy.Value);

    private async Task HandleSubmit()
    {
        var nrAlbumu = AppState.NrAlbumu;
        if (string.IsNullOrEmpty(nrAlbumu))
        {
            Snackbar.Add("Brak numeru albumu w kontekscie uzytkownika.", Severity.Error);
            return;
        }
        if (!IsValid) return;

        _submitting = true;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var idOsobyParam = _idOsoby.HasValue ? (object)_idOsoby.Value : DBNull.Value;

            await db.Database.ExecuteSqlRawAsync(
                "EXEC P_ZgloszeniePraktyki @NrAlbumu={0}, @IDFirmy={1}, @IDOpiekuna={2}, @RodzajPraktyki={3}, @DataRozpoczecia={4}, @DataZakonczenia={5}, @IDOsoby={6}",
                nrAlbumu,
                _idFirmy!.Value,
                _idOpiekuna!.Value,
                _rodzaj,
                DateOnly.FromDateTime(_dataRozp!.Value),
                DateOnly.FromDateTime(_dataZak!.Value),
                idOsobyParam);

            Snackbar.Add("Praktyka zgloszona - czeka na akceptacje pelnomocnika.", Severity.Success);
            Nav.NavigateTo("/student");
        }
        catch (Microsoft.Data.SqlClient.SqlException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Nieoczekiwany blad: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }
}
