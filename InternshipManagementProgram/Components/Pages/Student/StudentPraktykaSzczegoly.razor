@page "/student/praktyka/{Id:int}"
@rendermode InteractiveServer
@inject NavigationManager Nav

@code {
    // Szczegoly zostaly polaczone z lista (split layout z drawerem) - przekierowujemy na /student.
    [Parameter] public int Id { get; set; }

    protected override void OnInitialized() => Nav.NavigateTo("/student");
}
