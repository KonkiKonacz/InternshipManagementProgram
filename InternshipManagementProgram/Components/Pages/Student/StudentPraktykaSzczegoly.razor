@page "/student/praktyka/{Id:int}"
@attribute [Authorize(Roles = "student")]
@rendermode InteractiveServer
@inject IDbContextFactory<PraktykiStudenckieContext> DbFactory
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Szczegóły praktyki</PageTitle>

<MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Href="/student" Class="mb-2">Wróć</MudButton>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true"/>
}
else if (_p is null)
{
    <MudAlert Severity="Severity.Warning">Nie znaleziono praktyki lub nie masz do niej dostępu.</MudAlert>
}
else
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h5" GutterBottom="true">Praktyka #@_p.Idpraktyki — @_p.RodzajPraktyki</MudText>
        <MudChip T="string" Color="@StatusColor(_p.Status)">@_p.Status</MudChip>

        <MudGrid Class="mt-4">
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" GutterBottom="true">Student</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string">Nr albumu: <b>@_p.NrAlbumu</b></MudListItem>
                    <MudListItem T="string">Imię i nazwisko: @_p.ImieStudenta @_p.NazwiskoStudenta</MudListItem>
                    <MudListItem T="string">Email: @(_p.EmailStudenta ?? "—")</MudListItem>
                    <MudListItem T="string">Semestr: @_p.Semestr</MudListItem>
                    <MudListItem T="string">Kierunek: @_p.NazwaKierunku</MudListItem>
                    <MudListItem T="string">Wydział: @_p.NazwaWydzialu</MudListItem>
                </MudList>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6" GutterBottom="true">Firma</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string">Nazwa: <b>@_p.NazwaFirmy</b></MudListItem>
                    <MudListItem T="string">Adres: @_p.AdresFirmy</MudListItem>
                    <MudListItem T="string">Miasto: @_p.MiastoFirmy</MudListItem>
                </MudList>

                <MudText Typo="Typo.h6" GutterBottom="true" Class="mt-4">Opiekun</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string">@(_p.TytulOpiekuna ?? "") @_p.ImieOpiekuna @_p.NazwiskoOpiekuna</MudListItem>
                </MudList>

                @if (!string.IsNullOrEmpty(_p.ImieOsobyKontaktowej))
                {
                    <MudText Typo="Typo.h6" GutterBottom="true" Class="mt-4">Osoba kontaktowa</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string">@_p.ImieOsobyKontaktowej @_p.NazwiskoOsobyKontaktowej (@(_p.StanowiskoOsobyKontaktowej ?? "—"))</MudListItem>
                    </MudList>
                }
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.h6" GutterBottom="true" Class="mt-2">Daty i ocena</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string">Data zgłoszenia: @_p.DataZgloszenia.ToString("yyyy-MM-dd")</MudListItem>
                    <MudListItem T="string">Data rozpoczęcia: @(_p.DataRozpoczecia?.ToString("yyyy-MM-dd") ?? "—")</MudListItem>
                    <MudListItem T="string">Data zakończenia: @(_p.DataZakonczenia?.ToString("yyyy-MM-dd") ?? "—")</MudListItem>
                    <MudListItem T="string">Ocena: @(_p.Ocena?.ToString("0.0") ?? "—")</MudListItem>
                </MudList>
            </MudItem>
        </MudGrid>

        @if (_p.Status == "Zaliczona")
        {
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Download"
                       Href="@($"/student/zaswiadczenie/{_p.Idpraktyki}")" Class="mt-4">
                Pobierz zaświadczenie
            </MudButton>
        }
    </MudPaper>
}

@code {
    [Parameter] public int Id { get; set; }

    private VPraktykiPelne? _p;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var nrAlbumu = state.User.FindFirst("NrAlbumu")?.Value;
        if (string.IsNullOrEmpty(nrAlbumu))
        {
            _loading = false;
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        _p = await db.VPraktykiPelnes
            .FirstOrDefaultAsync(p => p.Idpraktyki == Id && p.NrAlbumu == nrAlbumu);
        _loading = false;
    }

    private static Color StatusColor(string status) => status switch
    {
        "Zgłoszona" => Color.Info,
        "Zatwierdzona" => Color.Primary,
        "Zakończona" => Color.Warning,
        "Zaliczona" => Color.Success,
        "Niezaliczona" => Color.Error,
        "Odrzucona" => Color.Error,
        _ => Color.Default
    };
}
