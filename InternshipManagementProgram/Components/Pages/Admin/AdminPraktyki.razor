@page "/admin"
@rendermode InteractiveServer
@inject IDbContextFactory<PraktykiStudenckieContext> DbFactory
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>Praktyki - PraktykiStud</PageTitle>

<div class="page-head">
    <div>
        <h1 class="page-title">Wszystkie praktyki</h1>
        <p class="page-sub">
            @if (!_loading)
            {
                <text>@_praktyki.Count praktyk w bazie. <strong style="color:var(--text-primary)">@_kpiOczekuje</strong> wymaga akceptacji.</text>
            }
            else { <text>Wczytywanie...</text> }
        </p>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="stats">
        <div class="stat">
            <div class="label"><span class="dot" style="background:var(--info)"></span>W trakcie</div>
            <div class="value">@_kpiWTrakcie</div>
            <div class="trend">aktualnie realizowane</div>
        </div>
        <div class="stat">
            <div class="label">
                <span class="dot" style="background:var(--warning);box-shadow:0 0 0 3px rgba(240,196,25,0.22)"></span>
                Do akceptacji
            </div>
            <div class="value">@_kpiOczekuje</div>
            <div class="trend">średnio 3 dni rob.</div>
        </div>
        <div class="stat">
            <div class="label"><span class="dot" style="background:var(--success)"></span>Zaliczone</div>
            <div class="value">@_kpiZaliczone</div>
            <div class="trend">bieżący rok akadem.</div>
        </div>
        <div class="stat">
            <div class="label"><span class="dot" style="background:var(--error)"></span>Niezaliczone</div>
            <div class="value">@_kpiNiezaliczone</div>
            <div class="trend">wymagają interwencji</div>
        </div>
    </div>

    <div class="card">
        <div class="filters">
            <div class="filter">
                <span class="filter-label">Status</span>
                <select class="field" @bind="_filterStatus">
                    <option value="">Wszystkie statusy</option>
                    @foreach (var s in _wszystkieStatusy)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="filter">
                <span class="filter-label">Student</span>
                <div class="search-field" style="min-width:220px">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                    <input placeholder="Imię, nazwisko lub nr albumu" @bind="_szukajStudent" @bind:event="oninput" />
                </div>
            </div>
            <div class="filter">
                <span class="filter-label">Firma</span>
                <input class="field" placeholder="Nazwa firmy" @bind="_filterFirma" @bind:event="oninput" />
            </div>
            <div class="filter">
                <span class="filter-label">Semestr</span>
                <select class="field" @bind="_filterSemestr">
                    <option value="">Wszystkie</option>
                    @for (int i = 1; i <= 8; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>
            <div class="filter-spacer"></div>
            @if (AnyFilter)
            {
                <button class="btn btn-text btn-sm" @onclick="ResetFilters">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" /> Wyczyść filtry
                </button>
            }
        </div>

        <div class="table-wrap">
            <table class="t">
                <thead>
                    <tr>
                        <th>ID / Student</th>
                        <th>Firma</th>
                        <th>Rodzaj</th>
                        <th>Daty</th>
                        <th>Semestr</th>
                        <th>Status</th>
                        <th style="text-align:center">Ocena</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var filtered = Filtrowane().ToList();
                    }
                    @if (filtered.Count == 0)
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty">
                                    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Large" />
                                    <div class="em-title">Brak wyników</div>
                                    <div class="em-sub">Spróbuj wyczyścić filtry lub zmienić zapytanie.</div>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var p in filtered)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px">
                                        <div class="avatar" style="width:30px;height:30px;font-size:11px">@InitialsOf(p.ImieStudenta, p.NazwiskoStudenta)</div>
                                        <div>
                                            <div style="font-weight:600;font-size:13px">@p.ImieStudenta @p.NazwiskoStudenta</div>
                                            <div class="t-meta">PR-@p.Idpraktyki.ToString("D5") - nr @p.NrAlbumu</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="t-company">
                                        <div class="t-logo" style="@($"background:{StatusInfo.GradientFor(p.NazwaFirmy)}")">
                                            @StatusInfo.Initials(p.NazwaFirmy)
                                        </div>
                                        <div>
                                            <div>@p.NazwaFirmy</div>
                                            <div class="t-meta">@p.MiastoFirmy</div>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="t-type">@p.RodzajPraktyki</span></td>
                                <td class="t-dates">
                                    @(p.DataRozpoczecia?.ToString("dd.MM.yy") ?? "—")
                                    <span style="opacity:.5">→</span>
                                    @(p.DataZakonczenia?.ToString("dd.MM.yy") ?? "—")
                                </td>
                                <td><span class="t-meta">sem. @p.Semestr</span></td>
                                <td>
                                    <button class="btn btn-text btn-sm @StatusInfo.ChipClass(p.Status)"
                                            style="padding:3px 9px"
                                            @onclick="() => OtworzZmianeStatusu(p)" title="Zmień status">
                                        <span class="dot"></span>@p.Status
                                    </button>
                                </td>
                                <td style="text-align:center">
                                    @if (p.Ocena.HasValue)
                                    {
                                        <button class="btn btn-text btn-sm"
                                                style="@($"padding:4px 10px;color:{(p.Ocena.Value >= 3 ? "var(--success)" : "var(--error)")};font-weight:700;font-variant-numeric:tabular-nums")"
                                                @onclick="() => OtworzWystawienieOceny(p)" title="Zmień ocenę">
                                            @p.Ocena.Value.ToString("0.0")
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-text btn-sm"
                                                style="padding:4px 10px;color:var(--text-disabled)"
                                                @onclick="() => OtworzWystawienieOceny(p)"
                                                disabled="@(p.Status != "Zakończona" && p.Status != "Zaliczona" && p.Status != "Niezaliczona")"
                                                title="Wystaw ocenę">
                                            —
                                        </button>
                                    }
                                </td>
                                <td style="text-align:right">
                                    <button class="icon-btn" @onclick="() => OtworzZmianeStatusu(p)" title="Akcje">
                                        <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="Size.Small" />
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div style="padding:12px 16px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;font-size:12.5px;color:var(--text-secondary)">
            <span>
                Wyświetlono <strong style="color:var(--text-primary)">@filtered.Count</strong>
                z <strong style="color:var(--text-primary)">@_praktyki.Count</strong> praktyk
            </span>
            <button class="btn btn-text btn-sm" @onclick="Reload">
                <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" /> Odśwież
            </button>
        </div>
    </div>
}

@code {
    private List<VPraktykiPelne> _praktyki = new();
    private bool _loading = true;

    private string? _filterStatus;
    private string? _filterFirma;
    private string? _filterSemestr;
    private string? _szukajStudent;

    private static readonly string[] _wszystkieStatusy =
        new[] { "Zgłoszona", "Zatwierdzona", "Odrzucona", "Zakończona", "Zaliczona", "Niezaliczona" };

    private int _kpiWTrakcie => _praktyki.Count(p => p.Status == "Zatwierdzona");
    private int _kpiOczekuje => _praktyki.Count(p => p.Status == "Zgłoszona");
    private int _kpiZaliczone => _praktyki.Count(p => p.Status == "Zaliczona");
    private int _kpiNiezaliczone => _praktyki.Count(p => p.Status == "Niezaliczona");

    private bool AnyFilter => !string.IsNullOrWhiteSpace(_filterStatus)
        || !string.IsNullOrWhiteSpace(_filterFirma)
        || !string.IsNullOrWhiteSpace(_filterSemestr)
        || !string.IsNullOrWhiteSpace(_szukajStudent);

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.IsAdmin)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await Reload();
    }

    private async Task Reload()
    {
        _loading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        _praktyki = await db.VPraktykiPelnes.OrderByDescending(p => p.DataZgloszenia).ToListAsync();
        _loading = false;
    }

    private void ResetFilters()
    {
        _filterStatus = null;
        _filterFirma = null;
        _filterSemestr = null;
        _szukajStudent = null;
    }

    private IEnumerable<VPraktykiPelne> Filtrowane()
    {
        IEnumerable<VPraktykiPelne> q = _praktyki;
        if (!string.IsNullOrWhiteSpace(_filterStatus)) q = q.Where(p => p.Status == _filterStatus);
        if (!string.IsNullOrWhiteSpace(_filterFirma)) q = q.Where(p => p.NazwaFirmy.Contains(_filterFirma, StringComparison.OrdinalIgnoreCase));
        if (int.TryParse(_filterSemestr, out var sem)) q = q.Where(p => p.Semestr == sem);
        if (!string.IsNullOrWhiteSpace(_szukajStudent))
        {
            var s = _szukajStudent.Trim();
            q = q.Where(p =>
                p.ImieStudenta.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                p.NazwiskoStudenta.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                p.NrAlbumu.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        return q;
    }

    private async Task OtworzZmianeStatusu(VPraktykiPelne p)
    {
        var parameters = new DialogParameters<ZmianaStatusuDialog>
        {
            { x => x.IdPraktyki, p.Idpraktyki },
            { x => x.AktualnyStatus, p.Status },
            { x => x.AktualnaDataRozp, p.DataRozpoczecia }
        };
        var dialog = await Dialog.ShowAsync<ZmianaStatusuDialog>("Zmiana statusu", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await Reload();
    }

    private async Task OtworzWystawienieOceny(VPraktykiPelne p)
    {
        var parameters = new DialogParameters<WystawienieOcenyDialog> { { x => x.IdPraktyki, p.Idpraktyki } };
        var dialog = await Dialog.ShowAsync<WystawienieOcenyDialog>("Wystawienie oceny", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await Reload();
    }

    private static string InitialsOf(string imie, string nazw)
    {
        var i = string.IsNullOrEmpty(imie) ? '?' : imie[0];
        var n = string.IsNullOrEmpty(nazw) ? '?' : nazw[0];
        return $"{char.ToUpper(i)}{char.ToUpper(n)}";
    }
}
