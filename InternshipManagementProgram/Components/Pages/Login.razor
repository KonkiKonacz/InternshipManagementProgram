@page "/login"
@rendermode InteractiveServer
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>Logowanie</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudPaper Class="pa-8" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">Logowanie (tryb demo)</MudText>
        <MudText Typo="Typo.body2" Class="mb-6">Wybierz konto, którym chcesz się zalogować.</MudText>

        <MudStack Spacing="3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.School" OnClick="ZalogujStudenta">
                Zaloguj jako student (nr albumu 62753)
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.AdminPanelSettings" OnClick="ZalogujAdmina">
                Zaloguj jako administrator
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private void ZalogujStudenta()
    {
        AppState.LoginAsStudent();
        Nav.NavigateTo("/student");
    }

    private void ZalogujAdmina()
    {
        AppState.LoginAsAdmin();
        Nav.NavigateTo("/admin");
    }
}
