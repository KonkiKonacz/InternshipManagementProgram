@page "/login"
@layout MainLayout
@rendermode InteractiveServer
@inject AppState AppState
@inject NavigationManager Nav

<PageTitle>Logowanie - System Rejestracji Praktyk Studenckich</PageTitle>

<div class="login-wrap">
    <div class="login-card">
        <div class="brand-col">
            <img src="img/logo.png" alt="System Rejestracji Praktyk Studenckich" />
            <h1>System Rejestracji Praktyk Studenckich</h1>
            <p class="subtitle">V1.0 - UBB</p>
        </div>

        <p class="page-sub login-sub">Wybierz konto demo, którym chcesz się zalogować.</p>

        <div class="actions">
            <button class="btn btn-primary" @onclick="ZalogujStudenta">
                <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" />
                Zaloguj jako student (nr 62753)
            </button>
            <button class="btn btn-outlined" @onclick="ZalogujAdmina">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" />
                Zaloguj jako administrator
            </button>
        </div>
    </div>
</div>

@code {
    private void ZalogujStudenta()
    {
        AppState.LoginAsStudent();
        Nav.NavigateTo("/student");
    }

    private void ZalogujAdmina()
    {
        AppState.LoginAsAdmin();
        Nav.NavigateTo("/admin");
    }
}
